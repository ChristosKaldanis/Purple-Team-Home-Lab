<!--
  Custom Wazuh Detection Rules
  Purple Team Home Lab Assessment
  Author: [Your Name]
  Date: April 2026
  
  Rules developed to close detection gaps identified during
  Purple Team attack simulation exercises.
  
  Add to: /var/ossec/etc/rules/local_rules.xml
  Restart: sudo systemctl restart wazuh-manager
-->

<group name="purple_team_custom,">

  <!-- ============================================
       RULE 100001: ProFTPD mod_copy RCE Detection
       CVE-2015-3306
       MITRE: T1190
       ============================================ -->
  <rule id="100001" level="10">
    <if_sid>11400</if_sid>
    <match>SITE CPFR</match>
    <description>ProFTPD mod_copy exploit attempt detected (CVE-2015-3306). Attacker may be attempting to copy files to web root for RCE.</description>
    <group>attack,ftp,exploit,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <!-- ============================================
       RULE 100002: PwnKit Privilege Escalation
       CVE-2021-4034 — pkexec abuse
       MITRE: T1068
       ============================================ -->
  <rule id="100002" level="15">
    <if_sid>5400</if_sid>
    <match>pkexec</match>
    <description>PwnKit privilege escalation attempt detected (CVE-2021-4034). Possible exploitation of polkit pkexec.</description>
    <group>attack,privesc,rootkit,</group>
    <mitre>
      <id>T1068</id>
    </mitre>
  </rule>

  <!-- ============================================
       RULE 100003: Suspicious .so file in /tmp
       Detects PwnKit payload dropped in /tmp
       MITRE: T1068
       ============================================ -->
  <rule id="100003" level="12">
    <if_sid>554</if_sid>
    <field name="file">/tmp/</field>
    <match>\.so</match>
    <description>Suspicious shared library (.so) created in /tmp directory. Possible exploit payload (PwnKit pattern).</description>
    <group>attack,privesc,suspicious_file,</group>
    <mitre>
      <id>T1068</id>
    </mitre>
  </rule>

  <!-- ============================================
       RULE 100004: SQL Injection Detection
       Payroll application attack
       MITRE: T1190
       ============================================ -->
  <rule id="100004" level="10">
    <if_sid>31100</if_sid>
    <url>payroll_app.php</url>
    <match>OR|UNION|SELECT|DROP|INSERT|1=1|--</match>
    <description>SQL Injection attempt detected on payroll application. Possible authentication bypass or data extraction.</description>
    <group>attack,web,sqli,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <!-- ============================================
       RULE 100005: Drupalgeddon2 RCE Detection
       CVE-2018-7600
       MITRE: T1190
       ============================================ -->
  <rule id="100005" level="12">
    <if_sid>31100</if_sid>
    <url>/drupal</url>
    <match>destination=render|#attached|#lazy_builder|ajax_form_callback</match>
    <description>Drupalgeddon2 RCE attempt detected (CVE-2018-7600). Malicious Drupal form API request.</description>
    <group>attack,web,exploit,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <!-- ============================================
       RULE 100006: Persistence — New User Created
       Post-exploitation persistence mechanism
       MITRE: T1136
       ============================================ -->
  <rule id="100006" level="14">
    <if_sid>5902</if_sid>
    <description>New user account created on system. Possible attacker persistence mechanism after compromise.</description>
    <group>attack,persistence,useradd,</group>
    <mitre>
      <id>T1136</id>
    </mitre>
  </rule>

  <!-- ============================================
       RULE 100007: SMB Null Session Enumeration
       MITRE: T1135
       ============================================ -->
  <rule id="100007" level="8">
    <if_sid>5713</if_sid>
    <match>anonymous|null session|enum4linux</match>
    <description>SMB null session enumeration detected. Attacker may be gathering user and share information.</description>
    <group>attack,smb,recon,</group>
    <mitre>
      <id>T1135</id>
    </mitre>
  </rule>

</group>
